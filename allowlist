# Optional domains loaded by init-firewall.sh on container start.
# Add one entry per line. Supports plain domains, IP addresses, CIDR ranges,
# and port-specific entries. Failures here are non-fatal (WARNING only).
#
# Port-specific syntax:  host:port[/proto]   (proto = tcp | udp, default tcp)
#   host.docker.internal:9222         → allow tcp/9222 to the Docker host
#   10.0.0.1:5353/udp                 → allow udp/5353 to a specific IP
#   myhost.local:8080/tcp             → allow tcp/8080 (explicit proto)
# Python package repositories

pypi.org
files.pythonhosted.org

# npm
registry.npmjs.org

# VSCode extension marketplace and updates
marketplace.visualstudio.com
vscode.blob.core.windows.net
update.code.visualstudio.com

# GitHub
# Any github.com or githubusercontent.com entry triggers a one-time fetch of
# all GitHub CIDR ranges from api.github.com/meta (using aggregate to combine
# them). This covers the full anycast fleet — plain DNS is not sufficient.
# Uncomment any one line to enable; listing multiple is harmless.

# Repo-serving domains — use path entries (DS-001 §8 guard will reject bare hosts)
github.com/dkantowitz/devcontainer-claude
github.com/dkantowitz/*
#raw.githubusercontent.com/dkantowitz/*
#codeload.github.com/dkantowitz/*
#objects.githubusercontent.com

# Telegram Bot API
api.telegram.org

# Addresses for Github Copilot.
# github.com / githubusercontent.com entries trigger CIDR fetch (not DNS).
# api.githubcopilot.com is a separate domain — resolved via DNS.

# DS-001: api.github.com and github.com are CIDR-family splice passthrough
# (OAuth flow, token exchange). NOT guarded — they serve non-repo purposes.
api.github.com                          # — auth/token, OAuth (CIDR; splice)
api.githubcopilot.com                   # — completions API (DNS)
copilot-proxy.githubusercontent.com     # — completions proxy (CIDR; splice)
copilot-telemetry.githubusercontent.com # — telemetry (CIDR; splice)
default.exp-tas.com                     # — feature flags (DNS)
github.com                              # — OAuth flow (CIDR; splice)

# VS Code telemetry (optional — Copilot works without this)
dc.services.visualstudio.com

# host computer for chrome debugging port (used with chrome dev MCP)
host.docker.internal:9222

# Docker Hub (base image pulls)
# Used for nested podman inside devcontainer.
# Podman is used to let claude autonomously build containers for the deployment artifact.
registry-1.docker.io
auth.docker.io
production.cloudflare.docker.com
r2.cloudflarestorage.com

# debian package repositories (for apt-get inside the container)
deb.debian.org
security.debian.org

# Google CIDR trigger (for init-firewall.sh Google IP range fetch)
www.gstatic.com
